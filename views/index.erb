<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>1NCE SIM Usage Checker</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <style>
    /* ---- override Bootstrap primary with brand coral ---- */
    :root, :root[data-bs-theme="light"] {
      --bs-primary:     #E8573A;
      --bs-primary-rgb: 232, 87, 58;
      --bs-link-color:  #E8573A;
      --bs-link-hover-color: #c9402a;
    }
    [data-bs-theme="dark"] {
      --bs-primary:     #F07A62;
      --bs-primary-rgb: 240, 122, 98;
      --bs-link-color:  #F07A62;
    }

    /* ---- app colour tokens ---- */
    :root {
      --brand-primary:  #E8573A;
      --brand-dark:     #2D2D3A;
      --body-bg:        #F5F3F1;
      --card-bg:        #FFFFFF;
      --card-border:    #E4D9D3;
      --text-main:      #1A1A2E;
      --text-muted:     #6B7280;
      --org-hover:      rgba(232,87,58,.08);
      --org-active:     rgba(232,87,58,.15);
      --row-hover:      rgba(232,87,58,.05);
      --stats-stripe:   #F5F1EF;
      --danger-bg:      #FDECEA;
      --danger-text:    #B71C1C;
      --warn-bg:        #FFF8E1;
      --warn-text:      #F57F17;
      --ok-bg:          #E8F5E9;
      --ok-text:        #1B5E20;
    }
    body.dark {
      --body-bg:        #12121E;
      --card-bg:        #1C1C2E;
      --card-border:    #2C2C42;
      --text-main:      #CDD3DE;
      --text-muted:     #8892A4;
      --org-hover:      rgba(232,87,58,.13);
      --org-active:     rgba(232,87,58,.25);
      --row-hover:      rgba(232,87,58,.09);
      --stats-stripe:   #171728;
      --danger-bg:      #3A1010;
      --danger-text:    #F48A8A;
      --warn-bg:        #342800;
      --warn-text:      #FFD54F;
      --ok-bg:          #102010;
      --ok-text:        #81C784;
    }

    body { background: var(--body-bg); font-size: 0.9rem; color: var(--text-main); }

    /* ---------- top bar ---------- */
    .topbar {
      background: var(--brand-dark);
      padding: 0.65rem 1.25rem;
      display: flex; align-items: center; gap: 0.75rem;
    }
    .topbar .logo { color: #fff; font-size: 1.25rem; font-weight: 700; letter-spacing: .03em; }
    .topbar .logo span { color: var(--brand-primary); }
    .topbar .subtitle { color: rgba(255,255,255,.55); font-size: .8rem; }
    .btn-dark-toggle {
      background: transparent; border: 1px solid rgba(255,255,255,.2);
      color: rgba(255,255,255,.75); border-radius: .4rem; padding: .25rem .55rem;
      font-size: .9rem; cursor: pointer; transition: background .15s; line-height: 1;
    }
    .btn-dark-toggle:hover { background: rgba(255,255,255,.1); }

    /* ---------- cards ---------- */
    .card { border: 1px solid var(--card-border) !important; border-radius: .75rem;
            box-shadow: 0 1px 4px rgba(0,0,0,.07); background: var(--card-bg) !important; }
    .card-header {
      background: var(--card-bg) !important;
      border-bottom: 1px solid var(--card-border) !important;
      border-radius: .75rem .75rem 0 0 !important;
      font-weight: 600; font-size: .85rem; color: var(--text-main);
    }
    .card-footer { background: var(--card-bg) !important; color: var(--text-muted) !important;
                   border-top: 1px solid var(--card-border) !important; }

    /* ---------- org list ---------- */
    .org-item {
      display: flex; align-items: center; gap: .5rem;
      padding: .45rem .75rem; border-radius: .5rem;
      cursor: pointer; transition: background .15s; user-select: none;
      color: var(--text-main);
    }
    .org-item:hover  { background: var(--org-hover); }
    .org-item.active { background: var(--org-active); font-weight: 600; }
    .org-item .badge-cred { font-size: .65rem; }

    /* ---------- results table ---------- */
    .table-results thead th {
      background: var(--brand-dark); color: #fff;
      font-weight: 500; font-size: .78rem; white-space: nowrap;
      position: sticky; top: 0; z-index: 2;
    }
    .table-results tbody tr { color: var(--text-main); }
    .table-results tbody tr:hover > td { background: var(--row-hover) !important; }
    .row-exhausted td { background: var(--danger-bg) !important; color: var(--danger-text); }
    .row-low       td { background: var(--warn-bg)   !important; color: var(--warn-text); }

    .vol-badge {
      display: inline-block; padding: .15rem .5rem; border-radius: 1rem;
      font-size: .75rem; font-weight: 600; min-width: 4rem; text-align: center;
    }
    .vol-zero { background: var(--danger-bg); color: var(--danger-text); }
    .vol-low  { background: var(--warn-bg);   color: var(--warn-text); }
    .vol-ok   { background: var(--ok-bg);     color: var(--ok-text); }

    /* ---------- stats ---------- */
    .stat-card { border-radius: .6rem; padding: .5rem .85rem; text-align: center; flex: 1 1 0; }
    .stat-card .num { font-size: 1.5rem; font-weight: 700; line-height: 1; }
    .stat-card .lbl { font-size: .7rem; color: var(--text-muted); margin-top: .15rem; }
    .stats-stripe { background: var(--stats-stripe) !important; color: var(--text-main) !important; }

    /* ---------- misc ---------- */
    .table-wrapper { max-height: 65vh; overflow-y: auto; border-radius: 0 0 .75rem .75rem; }
    .search-box { max-width: 260px; }
    #progressBar { transition: width .3s; }
    .iccid-copy { cursor: pointer; font-size: .75rem; opacity: .6; }
    .iccid-copy:hover { opacity: 1; }
    .filter-tabs .nav-link { font-size: .8rem; padding: .3rem .7rem; }

    /* ---------- dark mode extras ---------- */
    body.dark .form-control, body.dark .form-select, body.dark .input-group-text {
      background-color: #252540; color: var(--text-main); border-color: var(--card-border);
    }
    body.dark .form-control::placeholder { color: var(--text-muted); }
    body.dark .form-text, body.dark .text-muted { color: var(--text-muted) !important; }
    body.dark hr { border-color: var(--card-border); }
    body.dark .modal-content { background: var(--card-bg); color: var(--text-main); border-color: var(--card-border); }
    body.dark .modal-header, body.dark .modal-footer { border-color: var(--card-border); }
    body.dark .table { color: var(--text-main); --bs-table-bg: transparent; --bs-table-striped-bg: transparent; }
  </style>
</head>
<body>

<!-- Top bar -->
<div class="topbar">
  <div>
    <div class="logo">1<span>NCE</span> SIM Usage Checker</div>
    <div class="subtitle">Multi-organisation data quota monitor</div>
  </div>
  <button class="btn-dark-toggle ms-auto" onclick="toggleDark()" id="darkToggleBtn" title="Toggle dark mode">
    <i class="bi bi-moon-stars-fill"></i>
  </button>
</div>

<div class="container-fluid py-3 px-3">
  <div class="row g-3">

    <!-- ===== LEFT SIDEBAR: Orgs ===== -->
    <div class="col-lg-3 col-md-4">

      <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span><i class="bi bi-building me-1"></i>Organisations</span>
          <button class="btn btn-sm btn-primary py-0 px-2" style="font-size:.75rem"
                  onclick="openOrgModal()">
            <i class="bi bi-plus-lg"></i> Add
          </button>
        </div>
        <div class="card-body p-2" id="orgList">
          <div class="text-center text-muted py-3" style="font-size:.8rem">
            Loading…
          </div>
        </div>
      </div>

      <!-- Check buttons -->
      <div class="card">
        <div class="card-body p-3">
          <div class="d-grid gap-2">
            <button class="btn btn-primary" id="btnCheckAll" onclick="checkUsage(null)">
              <i class="bi bi-lightning-charge-fill me-1"></i>Check All Orgs
            </button>
            <button class="btn btn-outline-primary" id="btnCheckOne" disabled
                    onclick="checkUsage(selectedOrgId)">
              <i class="bi bi-check2-circle me-1"></i>Check Selected Org
            </button>
          </div>
          <hr class="my-2" />
          <button class="btn btn-sm btn-outline-warning w-100" id="btnInvalidateTokens"
                  onclick="invalidateTokens()" title="Force all orgs to re-authenticate on next check">
            <i class="bi bi-arrow-clockwise me-1"></i>Refresh Tokens
          </button>
        </div>
      </div>

      <!-- Export card -->
      <div class="card mt-3">
        <div class="card-header"><i class="bi bi-download me-1"></i>Export</div>
        <div class="card-body p-3">

          <!-- Scope selector — prominent, above buttons -->
          <div class="mb-2">
            <div class="fw-semibold mb-1" style="font-size:.75rem; text-transform:uppercase;
                 letter-spacing:.04em; color:var(--text-muted)">SIM scope</div>
            <div class="btn-group w-100" role="group">
              <input type="radio" class="btn-check" name="exportScope" id="scopeAll" value="all" />
              <label class="btn btn-sm btn-outline-secondary" for="scopeAll">All</label>
              <input type="radio" class="btn-check" name="exportScope" id="scopeNoData" value="no_data" checked />
              <label class="btn btn-sm btn-outline-danger" for="scopeNoData">No Data</label>
              <input type="radio" class="btn-check" name="exportScope" id="scopeIssues" value="issues" />
              <label class="btn btn-sm btn-outline-warning" for="scopeIssues">+ Low</label>
            </div>
          </div>

          <!-- Org scope pill -->
          <div class="mb-3 px-2 py-1 rounded d-flex align-items-center gap-1"
               style="font-size:.75rem; background:var(--stats-stripe); color:var(--text-muted)">
            <i class="bi bi-building" style="font-size:.7rem"></i>
            <span id="exportScopeLabel">All orgs</span>
          </div>

          <!-- Export buttons -->
          <div class="d-grid gap-2">
            <button class="btn btn-sm btn-outline-success" onclick="exportData('csv')">
              <i class="bi bi-filetype-csv me-1"></i>Export CSV
            </button>
            <button class="btn btn-sm btn-outline-success" onclick="exportData('excel')">
              <i class="bi bi-file-earmark-spreadsheet me-1"></i>Export Excel
            </button>
          </div>

        </div>
      </div>

    </div><!-- /sidebar -->

    <!-- ===== MAIN CONTENT ===== -->
    <div class="col-lg-9 col-md-8">

      <!-- Progress bar -->
      <div id="progressArea" style="display:none" class="mb-2">
        <div class="d-flex align-items-center gap-2 mb-1">
          <span id="progressLabel" style="font-size:.8rem; color:#555">Checking…</span>
          <span class="spinner-border spinner-border-sm text-primary"></span>
        </div>
        <div class="progress" style="height:6px">
          <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
               id="progressBar" style="width:100%"></div>
        </div>
      </div>

      <!-- Alerts -->
      <div id="alertArea"></div>

      <!-- Stats table (per-org breakdown) -->
      <div id="statsRow" style="display:none" class="mb-3">
        <div class="card">
          <div class="table-wrapper">
            <table class="table table-sm mb-0" style="font-size:.82rem">
              <thead>
                <tr class="stats-stripe">
                  <th>Organisation</th>
                  <th class="text-end">Total</th>
                  <th class="text-end" style="color:var(--danger-text)">No Data</th>
                  <th class="text-end" style="color:var(--warn-text)">&lt; 10 MB</th>
                  <th class="text-end" style="color:var(--ok-text)">OK</th>
                  <th class="text-end" style="color:#888">API Error</th>
                </tr>
              </thead>
              <tbody id="statsTableBody"></tbody>
              <tfoot id="statsTableFoot"></tfoot>
            </table>
          </div>
        </div>
      </div>

      <!-- Table controls -->
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2"
           id="tableControls" style="display:none!important">
        <ul class="nav nav-pills filter-tabs" id="filterTabs">
          <li class="nav-item">
            <a class="nav-link active" href="#" data-filter="problems" onclick="setFilter('problems');return false">
              ⚠ Issues <span class="badge bg-danger ms-1" id="tabBadgeProblems">0</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#" data-filter="all" onclick="setFilter('all');return false">All</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#" data-filter="exhausted" onclick="setFilter('exhausted');return false">
              No Data <span class="badge bg-danger ms-1" id="tabBadgeExhausted">0</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#" data-filter="low" onclick="setFilter('low');return false">
              Low &lt;10MB <span class="badge bg-warning text-dark ms-1" id="tabBadgeLow">0</span>
            </a>
          </li>
        </ul>
        <div class="d-flex gap-2 align-items-center">
          <input type="search" class="form-control form-control-sm search-box"
                 placeholder="Search ICCID / Label / MSISDN…"
                 id="searchInput" oninput="applyFilters()" />
          <select class="form-select form-select-sm" style="width:auto" id="orgFilter"
                  onchange="applyFilters()">
            <option value="">All orgs</option>
          </select>
        </div>
      </div>

      <!-- Table -->
      <div class="card" id="tableCard" style="display:none">
        <div class="table-wrapper">
          <table class="table table-sm table-hover mb-0 table-results">
            <thead>
              <tr>
                <th onclick="sortBy('org_name')"   class="sort-col" title="Sort">Org <i class="bi bi-arrow-down-up"></i></th>
                <th onclick="sortBy('iccid')"       class="sort-col">ICCID <i class="bi bi-arrow-down-up"></i></th>
                <th title="Open in 1NCE portal" style="width:2rem"></th>
                <th title="Advizeo infrastructure" style="width:2rem"></th>
                <th title="Advizeo admin" style="width:2rem"></th>
                <th onclick="sortBy('label')"       class="sort-col">Label <i class="bi bi-arrow-down-up"></i></th>
                <th onclick="sortBy('msisdn')"      class="sort-col">MSISDN <i class="bi bi-arrow-down-up"></i></th>
                <th onclick="sortBy('imsi')"        class="sort-col" title="Shown for low/no-data SIMs only">IMSI <i class="bi bi-arrow-down-up"></i></th>
                <th onclick="sortBy('sim_status')"  class="sort-col">Status <i class="bi bi-arrow-down-up"></i></th>
                <th onclick="sortBy('remaining_mb')" class="sort-col">Remaining <i class="bi bi-arrow-down-up"></i></th>
                <th onclick="sortBy('total_mb')"    class="sort-col">Total <i class="bi bi-arrow-down-up"></i></th>
                <th onclick="sortBy('expiry_date')" class="sort-col">Expiry <i class="bi bi-arrow-down-up"></i></th>
              </tr>
            </thead>
            <tbody id="simTableBody"></tbody>
          </table>
        </div>
        <div class="card-footer py-1 px-3" style="font-size:.75rem; color:#666; background:#fafafa">
          Showing <strong id="rowCount">0</strong> SIMs
          <span id="lastCheckedLabel" class="ms-3 text-muted"></span>
        </div>
      </div>

      <!-- Empty state -->
      <div id="emptyState" class="text-center py-5 text-muted">
        <i class="bi bi-sim-fill" style="font-size:3rem; opacity:.2"></i>
        <p class="mt-2">Select an organisation and click <strong>Check</strong> to view SIM usage data.</p>
      </div>

    </div>
  </div><!-- /row -->

  <!-- ===== Activity Log ===== -->
  <div class="row mt-3">
    <div class="col">
      <div class="card">
        <div class="card-header py-2 d-flex justify-content-between align-items-center"
             style="cursor:pointer" onclick="toggleLog()">
          <span><i class="bi bi-terminal me-1"></i>Activity Log</span>
          <div class="d-flex gap-2 align-items-center">
            <div class="form-check form-switch mb-0 me-1" onclick="event.stopPropagation()">
              <input class="form-check-input" type="checkbox" id="verboseLog" style="cursor:pointer" />
              <label class="form-check-label" for="verboseLog" style="font-size:.75rem; cursor:pointer; user-select:none">Verbose</label>
            </div>
            <button class="btn btn-sm btn-outline-secondary py-0 px-2" style="font-size:.75rem"
                    onclick="event.stopPropagation(); clearLog()">Clear</button>
            <i class="bi bi-chevron-down" id="logChevron"></i>
          </div>
        </div>
        <div id="logPanel"
             style="max-height:220px; overflow-y:auto; font-family:monospace; font-size:.78rem;
                    background:#1a1a2e; color:#cdd3de; padding:.6rem 1rem; display:none">
          <div class="text-muted" style="color:#555 !important">— log will appear here when you run a check —</div>
        </div>
      </div>
    </div>
  </div>

</div><!-- /container -->

<!-- ===== ORG MODAL ===== -->
<div class="modal fade" id="orgModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="orgModalTitle">Add Organisation</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="orgModalId" />
        <div class="mb-3">
          <label class="form-label fw-semibold">Organisation Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="orgName" placeholder="e.g. ACME GmbH" />
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Customer Number</label>
          <input type="text" class="form-control" id="orgCustomerNumber" placeholder="e.g. 10012345" />
        </div>
        <hr />
        <p class="text-muted" style="font-size:.8rem">
          <i class="bi bi-lock-fill me-1"></i>Credentials are stored only on the server and never sent to the browser.
        </p>
        <div class="mb-3">
          <label class="form-label fw-semibold">1NCE Username (email) <span class="text-danger">*</span></label>
          <input type="email" class="form-control" id="orgUsername" placeholder="user@example.com" />
          <div class="form-text" id="orgUsernameHint"></div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">1NCE Password <span class="text-danger" id="pwRequired">*</span></label>
          <div class="input-group">
            <input type="password" class="form-control" id="orgPassword" placeholder="••••••••" />
            <button class="btn btn-outline-secondary" type="button" id="togglePw"
                    onclick="togglePassword()"><i class="bi bi-eye"></i></button>
          </div>
          <div class="form-text" id="orgPasswordHint"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="orgSaveBtn" onclick="saveOrg()">
          <i class="bi bi-floppy me-1"></i>Save
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ===== CONFIRM DELETE MODAL ===== -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h6 class="modal-title">Remove Organisation?</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        Remove <strong id="deleteOrgName"></strong>? This cannot be undone.
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-sm btn-danger" id="confirmDeleteBtn">Remove</button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ===========================================================================
// State
// ===========================================================================
let allResults      = [];    // raw API results
let filteredResults = [];    // after filter/search
let orgs            = [];    // org list
let selectedOrgId   = null;
let currentFilter   = 'problems';
let sortField       = 'remaining_mb';
let sortAsc         = true;
let orgModal, deleteModal;

// ===========================================================================
// Init
// ===========================================================================
// Dark mode: restore preference before first paint
(function() {
  if (localStorage.getItem('darkMode') === '1') {
    document.documentElement.setAttribute('data-bs-theme', 'dark');
    document.body.classList.add('dark');
  }
})();

document.addEventListener('DOMContentLoaded', () => {
  orgModal    = new bootstrap.Modal(document.getElementById('orgModal'));
  deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
  // Sync toggle icon after DOM ready
  if (document.body.classList.contains('dark'))
    document.getElementById('darkToggleBtn').innerHTML = '<i class="bi bi-sun-fill"></i>';
  loadOrgs();
});

// ===========================================================================
// Org management
// ===========================================================================
async function loadOrgs() {
  const res  = await fetch('/api/orgs');
  orgs       = await res.json();
  orgs.sort((a, b) => a.name.localeCompare(b.name));
  renderOrgList();
}

function renderOrgList() {
  const el = document.getElementById('orgList');
  if (!orgs.length) {
    el.innerHTML = `<div class="text-center text-muted py-3" style="font-size:.8rem">
      No organisations yet.<br/>Click <strong>Add</strong> to get started.
    </div>`;
    return;
  }

  el.innerHTML = orgs.map(o => `
    <div class="org-item ${o.id === selectedOrgId ? 'active' : ''}"
         id="orgItem_${o.id}" onclick="selectOrg('${o.id}')">
      <i class="bi bi-building text-secondary" style="font-size:.85rem"></i>
      <div class="flex-grow-1 overflow-hidden">
        <div class="text-truncate" title="${esc(o.name)}">${esc(o.name)}</div>
        <div style="font-size:.7rem; color:#888">${esc(o.customer_number || '–')}</div>
      </div>
      <span class="badge ${o.has_credentials ? 'bg-success' : 'bg-warning text-dark'} badge-cred ms-auto"
            title="${o.has_credentials ? 'Credentials set' : 'No credentials'}">
        <i class="bi ${o.has_credentials ? 'bi-lock-fill' : 'bi-unlock-fill'}"></i>
      </span>
      <button class="btn btn-sm p-0 ms-1" style="font-size:.78rem; color:#888"
              onclick="event.stopPropagation(); openOrgModal('${o.id}')" title="Edit">
        <i class="bi bi-pencil"></i>
      </button>
      <button class="btn btn-sm p-0 ms-1" style="font-size:.78rem; color:#c00"
              onclick="event.stopPropagation(); confirmDelete('${o.id}', '${esc(o.name)}')" title="Remove">
        <i class="bi bi-trash"></i>
      </button>
    </div>
  `).join('');

  // Org filter dropdown in table
  const sel = document.getElementById('orgFilter');
  const cur = sel.value;
  sel.innerHTML = '<option value="">All orgs</option>' +
    orgs.map(o => `<option value="${o.id}" ${o.id === cur ? 'selected' : ''}>${esc(o.name)}</option>`).join('');

  updateExportLabel();
}

function selectOrg(id) {
  selectedOrgId = (selectedOrgId === id) ? null : id;
  document.getElementById('btnCheckOne').disabled = !selectedOrgId;
  renderOrgList();
  updateExportLabel();
}

function updateExportLabel() {
  const org = selectedOrgId ? orgs.find(o => o.id === selectedOrgId) : null;
  document.getElementById('exportScopeLabel').textContent = org ? org.name : 'All orgs';
}

// Modal helpers
function openOrgModal(id = null) {
  const editing = !!id;
  document.getElementById('orgModalTitle').textContent = editing ? 'Edit Organisation' : 'Add Organisation';
  document.getElementById('orgModalId').value          = id || '';
  document.getElementById('orgName').value             = '';
  document.getElementById('orgCustomerNumber').value   = '';
  document.getElementById('orgUsername').value         = '';
  document.getElementById('orgPassword').value         = '';
  document.getElementById('orgUsernameHint').textContent  = '';
  document.getElementById('orgPasswordHint').textContent  = '';
  document.getElementById('pwRequired').style.display     = editing ? 'none' : '';

  if (editing) {
    const o = orgs.find(x => x.id === id);
    if (o) {
      document.getElementById('orgName').value           = o.name;
      document.getElementById('orgCustomerNumber').value = o.customer_number || '';
      document.getElementById('orgUsernameHint').textContent  = 'Leave blank to keep existing value';
      document.getElementById('orgPasswordHint').textContent  = 'Leave blank to keep existing password';
    }
  }

  orgModal.show();
}

async function saveOrg() {
  const id   = document.getElementById('orgModalId').value;
  const body = {
    name:            document.getElementById('orgName').value.trim(),
    customer_number: document.getElementById('orgCustomerNumber').value.trim(),
    username:        document.getElementById('orgUsername').value.trim(),
    password:        document.getElementById('orgPassword').value
  };

  if (!body.name) { flash('danger', 'Organisation name is required.'); return; }
  if (!id && !body.username) { flash('danger', 'Username is required for new organisations.'); return; }

  const url    = id ? `/api/orgs/${id}` : '/api/orgs';
  const method = id ? 'PUT' : 'POST';
  const res    = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
  const data   = await res.json();

  if (!res.ok) { flash('danger', data.error || 'Save failed.'); return; }

  orgModal.hide();
  flash('success', id ? 'Organisation updated.' : 'Organisation added.');
  await loadOrgs();
}

function confirmDelete(id, name) {
  document.getElementById('deleteOrgName').textContent = name;
  document.getElementById('confirmDeleteBtn').onclick  = () => deleteOrg(id);
  deleteModal.show();
}

async function deleteOrg(id) {
  await fetch(`/api/orgs/${id}`, { method: 'DELETE' });
  deleteModal.hide();
  if (selectedOrgId === id) selectedOrgId = null;
  await loadOrgs();
  // Remove from results
  allResults = allResults.filter(r => r.org_id !== id);
  applyFilters();
}

function togglePassword() {
  const inp = document.getElementById('orgPassword');
  const btn = document.getElementById('togglePw');
  inp.type = inp.type === 'password' ? 'text' : 'password';
  btn.innerHTML = inp.type === 'password' ? '<i class="bi bi-eye"></i>' : '<i class="bi bi-eye-slash"></i>';
}

// ===========================================================================
// Usage check
// ===========================================================================
async function checkUsage(orgId) {
  document.getElementById('btnCheckAll').disabled = true;
  document.getElementById('btnCheckOne').disabled = true;
  document.getElementById('alertArea').innerHTML  = '';
  document.getElementById('emptyState').style.display = 'none';

  // Open the log panel automatically
  setLogOpen(true);

  const orgsToCheck = orgId ? orgs.filter(o => o.id === orgId) : [...orgs];
  if (!orgsToCheck.length) {
    flash('danger', 'No organisations to check.');
    document.getElementById('btnCheckAll').disabled = false;
    return;
  }

  log(`Starting check for ${orgsToCheck.length} organisation(s)…`, 'info');
  const globalStart = Date.now();
  let accumulated   = orgId
    ? allResults.filter(r => r.org_id !== orgId)   // keep other orgs' results
    : [];

  for (const org of orgsToCheck) {
    showProgress(`Checking ${org.name}…`);
    log(`→ ${org.name} (${org.customer_number || 'no cust. no.'}) — requesting quota data…`, 'info');
    const t0 = Date.now();

    try {
      const verbose = document.getElementById('verboseLog').checked;
      const res  = await fetch(`/api/check?org_id=${encodeURIComponent(org.id)}${verbose ? '&verbose=true' : ''}`);
      const data = await res.json();
      const elapsed = ((Date.now() - t0) / 1000).toFixed(1);

      if (!res.ok) {
        log(`  ✗ ${org.name}: ${data.error || 'unknown error'}`, 'error');
        flash('warning', `<strong>${esc(org.name)}:</strong> ${esc(data.error || 'Check failed')}`);
        continue;
      }

      const results   = data.results || [];
      const exhausted = results.filter(r => r.remaining_mb === 0).length;
      const low       = results.filter(r => r.remaining_mb > 0 && r.remaining_mb < 10).length;
      const ok        = results.length - exhausted - low;

      log(`  ✓ ${results.length} SIMs — ${exhausted} exhausted, ${low} low, ${ok} ok — ${elapsed}s`, 'success');
      if (data.request_log && data.request_log.length) {
        data.request_log.forEach(entry => {
          const resp = entry.response ? '  ' + JSON.stringify(entry.response) : '';
          const type = entry.status >= 400 ? 'error' : 'info';
          log(`    ${entry.method} ${entry.path} → ${entry.status}${resp}`, type);
        });
      }

      if (data.errors && data.errors.length) {
        data.errors.forEach(e => {
          log(`  ⚠ ${e.org_name}: ${e.error}`, 'warn');
          flash('warning', `<strong>${esc(e.org_name)}:</strong> ${esc(e.error)}`);
        });
      }

      accumulated = accumulated.filter(r => r.org_id !== org.id).concat(results);

    } catch (err) {
      const elapsed = ((Date.now() - t0) / 1000).toFixed(1);
      log(`  ✗ ${org.name}: network error after ${elapsed}s — ${err.message}`, 'error');
      flash('danger', `<strong>${esc(org.name)}:</strong> Network error — ${esc(err.message)}`);
    }
  }

  const totalElapsed   = ((Date.now() - globalStart) / 1000).toFixed(1);
  const totalExhausted = accumulated.filter(r => !r.fetch_error && r.remaining_mb <= 0).length;
  const totalErrors    = accumulated.filter(r => r.fetch_error).length;
  const errNote        = totalErrors ? `, ${totalErrors} API errors` : '';
  log(`Done — ${accumulated.length} SIMs across ${orgsToCheck.length} org(s), ${totalExhausted} exhausted${errNote} — ${totalElapsed}s total`, 'info');

  allResults = accumulated;
  document.getElementById('lastCheckedLabel').textContent =
    'Last checked: ' + new Date().toLocaleTimeString();

  hideProgress();
  document.getElementById('btnCheckAll').disabled = false;
  document.getElementById('btnCheckOne').disabled = !selectedOrgId;
  applyFilters();
  updateStats();
  await enrichResults();
}

// ===========================================================================
// Filtering & Sorting
// ===========================================================================
function setFilter(f) {
  currentFilter = f;
  document.querySelectorAll('[data-filter]').forEach(el => {
    el.classList.toggle('active', el.dataset.filter === f);
  });
  applyFilters();
}

function applyFilters() {
  const q      = document.getElementById('searchInput').value.toLowerCase();
  const orgF   = document.getElementById('orgFilter').value;

  filteredResults = allResults.filter(r => {
    const exhausted = !r.fetch_error && r.remaining_mb <= 0;
    const low       = !r.fetch_error && r.remaining_mb > 0 && r.remaining_mb < 10;
    if (currentFilter === 'problems'  && !exhausted && !low) return false;
    if (currentFilter === 'exhausted' && !exhausted) return false;
    if (currentFilter === 'low'       && !low) return false;
    if (orgF && r.org_id !== orgF) return false;
    if (q) {
      const hay = (r.iccid + r.label + r.msisdn + r.ip_address).toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });

  sortResults();
  renderTable();
}

function sortBy(field) {
  if (sortField === field) sortAsc = !sortAsc;
  else { sortField = field; sortAsc = true; }
  sortResults();
  renderTable();
}

function sortResults() {
  filteredResults.sort((a, b) => {
    let va = a[sortField], vb = b[sortField];
    // Nulls always sort last (ascending) or first (descending)
    if (va === null && vb === null) return 0;
    if (va === null) return sortAsc ? 1 : -1;
    if (vb === null) return sortAsc ? -1 : 1;
    if (typeof va === 'number') return sortAsc ? va - vb : vb - va;
    va = String(va || '').toLowerCase();
    vb = String(vb || '').toLowerCase();
    return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
  });
}

// ===========================================================================
// Table rendering
// ===========================================================================
function renderTable() {
  const tbody = document.getElementById('simTableBody');

  if (!filteredResults.length) {
    tbody.innerHTML = `<tr><td colspan="12" class="text-center text-muted py-4">No SIMs match the current filter.</td></tr>`;
  } else {
    tbody.innerHTML = filteredResults.map(r => {
      const isError    = !!r.fetch_error;
      const isExhaust  = !isError && r.remaining_mb <= 0;
      const isLow      = !isError && r.remaining_mb > 0 && r.remaining_mb < 10;
      const rowClass   = isError ? '' : isExhaust ? 'row-exhausted' : isLow ? 'row-low' : 'row-ok';
      const volClass   = isError ? '' : isExhaust ? 'vol-zero' : isLow ? 'vol-low' : 'vol-ok';
      let   volLabel;
      if (isError) {
        volLabel = `<span class="badge bg-secondary" title="${esc(r.fetch_error)}">API Error</span>`;
      } else if (r.remaining_mb <= 0) {
        volLabel = `<span class="vol-badge vol-zero">${r.remaining_mb < 0 ? r.remaining_mb.toFixed(2) + ' MB' : '0 MB'}</span>`;
      } else if (r.remaining_mb < 1) {
        volLabel = `<span class="vol-badge vol-low">${(r.remaining_mb * 1024).toFixed(1)} KB</span>`;
      } else {
        volLabel = `<span class="vol-badge vol-ok">${r.remaining_mb.toFixed(2)} MB</span>`;
      }
      const totLabel = r.total_mb != null ? r.total_mb.toFixed(0) + ' MB' : '–';
      const expLabel = r.expiry_date ? r.expiry_date.substring(0,10) : '–';
      const iccid    = esc(r.iccid);

      return `<tr class="${rowClass}">
        <td class="text-truncate" style="max-width:120px" title="${esc(r.org_name)}">${esc(r.org_name)}</td>
        <td>
          <span class="font-monospace" style="font-size:.78rem">${iccid}</span>
          <i class="bi bi-clipboard iccid-copy ms-1" onclick="copy('${iccid}')" title="Copy ICCID"></i>
        </td>
        <td style="text-align:center">
          ${r.portal_url
            ? `<a href="${r.portal_url}" target="_blank" rel="noopener" title="Open in 1NCE portal" style="font-size:.85rem; color:var(--brand-primary)"><i class="bi bi-box-arrow-up-right"></i></a>`
            : ''}
        </td>
        <td style="text-align:center">
          ${r.infra_url
            ? `<a href="${r.infra_url}" target="_blank" rel="noopener" title="${r.serial_number ? esc(r.serial_number) + ' – ' : ''}Advizeo infrastructure" style="font-size:.85rem; color:var(--brand-primary)"><i class="bi bi-hdd-network"></i></a>`
            : ''}
        </td>
        <td style="text-align:center">
          ${r.admin_url
            ? `<a href="${r.admin_url}" target="_blank" rel="noopener" title="${r.serial_number ? esc(r.serial_number) + ' – ' : ''}Comgy admin" style="font-size:.85rem; color:var(--brand-primary)"><i class="bi bi-gear"></i></a>`
            : ''}
        </td>
        <td>${esc(r.label) || '<span class="text-muted">–</span>'}</td>
        <td class="font-monospace" style="font-size:.78rem">${esc(r.msisdn) || '–'}</td>
        <td class="font-monospace" style="font-size:.78rem">${(isExhaust || isLow) && r.imsi ? esc(r.imsi) : '<span class="text-muted">–</span>'}</td>
        <td>${simStatusBadge(r.sim_status)}</td>
        <td>${volLabel}</td>
        <td style="color:#999; font-size:.78rem">${totLabel}</td>
        <td style="font-size:.78rem">${expLabel}</td>
      </tr>`;
    }).join('');
  }

  document.getElementById('rowCount').textContent = filteredResults.length;
  showTableArea();
}

function simStatusBadge(status) {
  if (!status) return '<span class="text-muted">–</span>';
  const cls = status.toLowerCase() === 'enabled' ? 'bg-success' : 'bg-secondary';
  return `<span class="badge ${cls}">${esc(status)}</span>`;
}

function showTableArea() {
  document.getElementById('tableCard').style.display     = '';
  document.getElementById('tableControls').style.display = '';
  document.getElementById('statsRow').style.display      = '';
  document.getElementById('emptyState').style.display    = 'none';
}

function updateStats() {
  const orgIds = [...new Set(allResults.map(r => r.org_id))];

  let totalEx = 0, totalLow = 0;

  const rows = orgIds.map(oid => {
    const rs       = allResults.filter(r => r.org_id === oid);
    const name     = rs[0].org_name;
    const total    = rs.length;
    const errors   = rs.filter(r => r.fetch_error).length;
    const exhaust  = rs.filter(r => !r.fetch_error && r.remaining_mb <= 0).length;
    const low      = rs.filter(r => !r.fetch_error && r.remaining_mb > 0 && r.remaining_mb < 10).length;
    const ok       = total - exhaust - low - errors;
    totalEx += exhaust; totalLow += low;
    const exStyle  = exhaust > 0 ? `color:var(--danger-text);font-weight:600` : 'color:#aaa';
    const lowStyle = low     > 0 ? `color:var(--warn-text);font-weight:600`   : 'color:#aaa';
    const errStyle = errors  > 0 ? `color:#888;font-style:italic`             : 'color:#ddd';
    return `<tr>
      <td>${esc(name)}</td>
      <td class="text-end">${total}</td>
      <td class="text-end" style="${exStyle}">${exhaust}</td>
      <td class="text-end" style="${lowStyle}">${low}</td>
      <td class="text-end" style="color:var(--ok-text)">${ok}</td>
      <td class="text-end" style="${errStyle}">${errors || '–'}</td>
    </tr>`;
  });

  const grand = allResults.length;
  const gErr  = allResults.filter(r => r.fetch_error).length;
  const gEx   = allResults.filter(r => !r.fetch_error && r.remaining_mb <= 0).length;
  const gLow  = allResults.filter(r => !r.fetch_error && r.remaining_mb > 0 && r.remaining_mb < 10).length;
  const gOk   = grand - gEx - gLow - gErr;

  document.getElementById('statsTableBody').innerHTML = rows.join('');
  document.getElementById('statsTableFoot').innerHTML = `<tr class="stats-stripe" style="font-weight:600">
    <td>Total</td>
    <td class="text-end">${grand}</td>
    <td class="text-end" style="color:var(--danger-text)">${gEx}</td>
    <td class="text-end" style="color:var(--warn-text)">${gLow}</td>
    <td class="text-end" style="color:var(--ok-text)">${gOk}</td>
    <td class="text-end" style="color:#888">${gErr || '–'}</td>
  </tr>`;

  document.getElementById('tabBadgeProblems').textContent  = gEx + gLow;
  document.getElementById('tabBadgeExhausted').textContent = gEx;
  document.getElementById('tabBadgeLow').textContent       = gLow;
}

// ===========================================================================
// Metabase enrichment – adds Advizeo infra & admin links
// ===========================================================================
async function enrichResults() {
  const imsis = [...new Set(
    allResults
      .filter(r => !r.fetch_error && r.remaining_mb < 10 && r.imsi)
      .map(r => r.imsi)
  )];
  if (!imsis.length) return;

  log(`Enriching ${imsis.length} SIM(s) with internal links…`, 'info');
  try {
    const res  = await fetch('/api/enrich', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ imsis })
    });
    const data = await res.json();
    if (data.error) { log(`  ⚠ Metabase enrichment: ${data.error}`, 'warn'); return; }

    const enriched = data.enriched || {};
    let count = 0;
    allResults.forEach(r => {
      const e = enriched[r.imsi];
      if (e) {
        r.infra_url     = e.infra_url     || '';
        r.admin_url     = e.admin_url     || '';
        r.serial_number = e.serial_number || '';
        count++;
      }
    });
    if (count) {
      log(`  ✓ Enriched ${count} SIM(s) with internal links`, 'success');
      applyFilters();
    }
  } catch (err) {
    log(`  ✗ Metabase enrichment error: ${err.message}`, 'error');
  }
}

// ===========================================================================
// Export  (POST already-loaded results – no re-fetch)
// ===========================================================================
async function exportData(format) {
  if (!allResults.length) { flash('warning', 'No data loaded — run a check first.'); return; }

  const orgId = selectedOrgId || '';
  const scope = document.querySelector('input[name="exportScope"]:checked')?.value || 'no_data';

  let rows = orgId ? allResults.filter(r => r.org_id === orgId) : [...allResults];
  if      (scope === 'no_data') rows = rows.filter(r => !r.fetch_error && r.remaining_mb <= 0);
  else if (scope === 'issues')  rows = rows.filter(r => !r.fetch_error && r.remaining_mb < 10);
  // scope === 'all': keep all rows

  if (!rows.length) { flash('warning', 'No rows match the current export criteria.'); return; }

  const scopeLabel = scope === 'no_data' ? 'No Data' : scope === 'issues' ? 'No Data + Low' : 'All';
  log(`Exporting ${rows.length} rows (${scopeLabel}) as ${format.toUpperCase()}…`, 'info');

  try {
    const res = await fetch(`/api/export?format=${format}`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(rows)
    });
    if (!res.ok) { flash('danger', 'Export failed: ' + res.statusText); return; }

    const blob        = await res.blob();
    const url         = URL.createObjectURL(blob);
    const a           = document.createElement('a');
    const orgSlug     = orgId
      ? (orgs.find(o => o.id === orgId)?.name || 'org').toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '')
      : null;
    const scopeSuffix = scope === 'no_data' ? 'no_data' : scope === 'issues' ? 'issues' : 'usage';
    const baseName    = orgSlug ? `${orgSlug}_${scopeSuffix}` : `sims_${scopeSuffix}`;
    const fname       = res.headers.get('Content-Disposition')?.match(/filename="([^"]+)"/)?.[1]
                        || `${baseName}.${format}`;
    a.href            = url;
    a.download        = fname;
    a.click();
    URL.revokeObjectURL(url);
    log(`✓ Export ready: ${fname}`, 'success');
  } catch (err) {
    flash('danger', 'Export error: ' + err.message);
  }
}

function toggleDark() {
  const isDark = document.body.classList.toggle('dark');
  document.documentElement.setAttribute('data-bs-theme', isDark ? 'dark' : 'light');
  document.getElementById('darkToggleBtn').innerHTML =
    isDark ? '<i class="bi bi-sun-fill"></i>' : '<i class="bi bi-moon-stars-fill"></i>';
  localStorage.setItem('darkMode', isDark ? '1' : '0');
}

async function invalidateTokens() {
  const btn = document.getElementById('btnInvalidateTokens');
  btn.disabled = true;
  try {
    const res = await fetch('/api/tokens/invalidate', { method: 'POST' });
    if (res.ok) {
      log('Token cache cleared — all orgs will re-authenticate on next check.', 'warn');
      flash('success', 'Token cache cleared. Next check will fetch fresh tokens.');
    } else {
      flash('danger', 'Failed to clear token cache.');
    }
  } catch (err) {
    flash('danger', 'Error: ' + err.message);
  } finally {
    btn.disabled = false;
  }
}

// ===========================================================================
// Progress / alert helpers
// ===========================================================================
function showProgress(label) {
  document.getElementById('progressLabel').textContent = label;
  document.getElementById('progressArea').style.display = '';
}
function hideProgress() {
  document.getElementById('progressArea').style.display = 'none';
}

function flash(type, msg) {
  const id = 'alert_' + Date.now();
  const el = document.createElement('div');
  el.className   = `alert alert-${type} alert-dismissible fade show py-2 px-3 mb-2`;
  el.style.fontSize = '.83rem';
  el.innerHTML   = `${msg} <button type="button" class="btn-close py-2" data-bs-dismiss="alert"></button>`;
  el.id          = id;
  document.getElementById('alertArea').prepend(el);
  if (type === 'success') setTimeout(() => el.remove(), 4000);
}

// ===========================================================================
// Activity log
// ===========================================================================
function log(msg, type = 'info') {
  const panel = document.getElementById('logPanel');
  const colours = { info: '#90caf9', success: '#a5d6a7', warn: '#ffe082', error: '#ef9a9a' };
  const time = new Date().toLocaleTimeString();
  const line = document.createElement('div');
  line.style.color = colours[type] || '#cdd3de';
  line.textContent = `[${time}] ${msg}`;
  // Remove placeholder if still there
  const placeholder = panel.querySelector('.text-muted');
  if (placeholder) placeholder.remove();
  panel.appendChild(line);
  panel.scrollTop = panel.scrollHeight;
}

function clearLog() {
  const panel = document.getElementById('logPanel');
  panel.innerHTML = '<div style="color:#555">— cleared —</div>';
}

function setLogOpen(open) {
  const panel   = document.getElementById('logPanel');
  const chevron = document.getElementById('logChevron');
  panel.style.display   = open ? '' : 'none';
  chevron.className     = open ? 'bi bi-chevron-up' : 'bi bi-chevron-down';
}

function toggleLog() {
  const panel = document.getElementById('logPanel');
  setLogOpen(panel.style.display === 'none');
}

// ===========================================================================
// Utility
// ===========================================================================
function esc(str) {
  return String(str || '')
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function copy(text) {
  navigator.clipboard.writeText(text).then(() => flash('success', `Copied: ${text}`));
}
